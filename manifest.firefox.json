{
  "manifest_version": 2,
  "name": "Video Playback Tracker",
  "version": "2.0.4",
  "description": "Automatically tracks your last watched video timestamp on any streaming site and reminds you when you return.",
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "alarms",
    "identity"
  ],
  "content_security_policy": "script-src 'self' 'wasm-unsafe-eval' https://*.googleapis.com https://*.firebaseio.com; object-src 'self';",
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "oauth2": {
    "client_id": "743702437264-peidajr25fgo9285rlu947k8iul50u01.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Video Playback Tracker"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "video-playback-tracker@extension",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "personallyIdentifyingInfo",
          "websiteActivity"
        ]
      }
    }
  },
  "host_permissions": [
    "<all_urls>",
    "https://*.firebaseio.com/*",
    "https://*.googleapis.com/*",
    "https://*.firebaseapp.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Video Playback Tracker"
  }
}