{
  "manifest_version": 3,
  "name": "Video Playback Tracker",
  "version": "2.0.1",
  "description": "Automatically tracks your last watched video timestamp on any streaming site and reminds you when you return.",
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "alarms",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://*.firebaseio.com/*",
    "https://*.googleapis.com/*",
    "https://*.firebaseapp.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Video Playback Tracker"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "video-playback-tracker@extension",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["personallyIdentifyingInfo", "websiteActivity"]
      }
    }
  }
}
